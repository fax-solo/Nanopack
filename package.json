{
  "name": "nanopack",
  "version": "1.0.0",
  "description": "A desktop application that packs files, photos, and videos into a single portable archive.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && vite",
    "build": "tsc && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:all": "npm run build:main && npm run build:preload && npm run build",
    "start": "npm run build:all && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "download-vendor": "ts-node scripts/download-vendor.ts",
    "install-vendor": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"ESNext\",\"moduleResolution\":\"bundler\"}' ts-node scripts/install-all-vendor.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "better-sqlite3@12.11.1": true
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
